/* pages/login/login.wxss */

.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #FAFEFC;
}

.login-logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  background: #6C63FF;
  color: white;
  font-size: 56rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(108, 99, 255, 0.3);
}

.app-name {
  font-size: 40rpx;
  font-weight: 500;
  color: #2D2D3F;
  margin-bottom: 8rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: #9898B0;
}

.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0 80rpx;
  box-sizing: border-box;
}

.login-btn {
  width: 100% !important;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: #6C63FF;
  color: white;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(108, 99, 255, 0.3);
}

.login-btn::after {
  border: none;
}

.login-tip {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #9898B0;
}
