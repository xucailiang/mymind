/* pages/canvas/canvas.wxss */

/* 外层视口 */
.viewport {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  position: relative;
  background: #FAFEFC;
}

/* 画布层 */
.canvas-layer {
  width: 9999rpx;
  height: 9999rpx;
  position: absolute;
  top: 0;
  left: 0;
  background-image: radial-gradient(circle, rgba(108, 99, 255, 0.08) 1.5rpx, transparent 1.5rpx);
  background-size: 40rpx 40rpx;
  background-position: 0 0;
}

/* ===== 拖拽 Ghost ===== */
.ghost {
  position: absolute;
  border: 2rpx dashed rgba(108, 99, 255, 0.4);
  border-radius: 16rpx;
  background: rgba(108, 99, 255, 0.04);
  pointer-events: none;
  z-index: 0;
}

.ghost--text {
  background: rgba(255, 234, 167, 0.15);
  border-color: rgba(255, 234, 167, 0.5);
}

.ghost--image {
  background: rgba(189, 224, 254, 0.15);
  border-color: rgba(189, 224, 254, 0.5);
}

.ghost--audio {
  background: rgba(228, 220, 255, 0.15);
  border-color: rgba(228, 220, 255, 0.5);
}

/* 空状态提示 */
.empty-state {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 0;
}

.empty-state__icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-state__text {
  font-size: 30rpx;
  color: #A0A0B0;
}

/* ===== 长按上下文菜单 ===== */
.context-menu-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  background: rgba(0, 0, 0, 0);
}

.context-menu {
  position: absolute;
  min-width: 200rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
  padding: 8rpx 0;
  animation: menuAppear 180ms ease-out;
  /* 防止菜单超出屏幕 */
  max-width: 60vw;
}

.context-menu__item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 32rpx;
  transition: background 0.12s;
}

.context-menu__item:active {
  background: rgba(108, 99, 255, 0.06);
}

.context-menu__item--danger:active {
  background: rgba(231, 76, 60, 0.06);
}

.context-menu__icon {
  font-size: 28rpx;
  line-height: 1;
}

.context-menu__label {
  font-size: 26rpx;
  color: #4A4A5A;
  line-height: 1;
}

.context-menu__item--danger .context-menu__label {
  color: #E74C3C;
}

.context-menu__divider {
  height: 1rpx;
  background: #F0F0F5;
  margin: 4rpx 24rpx;
}

@keyframes menuAppear {
  0% { transform: scale(0.85); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* ===== 右侧控制面板 ===== */
.side-panel {
  position: fixed;
  top: 100rpx;
  right: 24rpx;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  align-items: flex-end;
}

.side-panel__row {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.side-panel__btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s;
}

.side-panel__btn:active {
  background: rgba(108, 99, 255, 0.08);
}

.side-panel__btn--disabled {
  opacity: 0.3;
}

.side-panel__btn--disabled:active {
  background: transparent;
}

.side-panel__btn--text {
  width: auto;
  padding: 0 24rpx;
  min-width: 64rpx;
}

.side-panel__icon {
  font-size: 30rpx;
  color: #4A4A5A;
  line-height: 1;
}

.side-panel__zoom-text {
  font-size: 32rpx;
  color: #4A4A5A;
  line-height: 1;
  font-weight: 500;
}

.side-panel__scale-text {
  min-width: 80rpx;
  text-align: center;
  font-size: 22rpx;
  color: #6C63FF;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  line-height: 64rpx;
}

.side-panel__label {
  font-size: 22rpx;
  color: #6C63FF;
  font-weight: 500;
  line-height: 1;
}

/* ===== 选中工具栏 ===== */
.selection-bar {
  position: fixed;
  bottom: 180rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #FFFFFF;
  border-radius: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(108, 99, 255, 0.12);
  padding: 0 8rpx;
  z-index: 1000;
  animation: barSlideUp 200ms ease-out;
}

.selection-bar__btn {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  height: 56rpx;
  border-radius: 28rpx;
  transition: background 0.15s;
}

.selection-bar__btn:active {
  background: rgba(108, 99, 255, 0.08);
}

.selection-bar__btn--danger:active {
  background: rgba(255, 80, 80, 0.08);
}

.selection-bar__label {
  font-size: 24rpx;
  color: #4A4A5A;
  line-height: 1;
}

.selection-bar__btn--danger .selection-bar__label {
  color: #E74C3C;
}

.selection-bar__divider {
  width: 1rpx;
  height: 32rpx;
  background: #E8E8F0;
  margin: 0 4rpx;
}

@keyframes barSlideUp {
  0% { transform: translateX(-50%) translateY(20rpx); opacity: 0; }
  100% { transform: translateX(-50%) translateY(0); opacity: 1; }
}

/* ===== 底部工具栏 ===== */
.toolbar {
  position: fixed;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  height: 88rpx;
  background: #FFFFFF;
  border-radius: 44rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  padding: 0 12rpx;
  z-index: 1000;
}

.toolbar__btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 28rpx;
  border-radius: 36rpx;
  transition: background 0.2s;
}

.toolbar__btn:active {
  background: rgba(108, 99, 255, 0.08);
}

.toolbar__btn--record {
  position: relative;
}

.toolbar__btn--recording {
  background: rgba(255, 80, 80, 0.08);
}

.toolbar__icon {
  font-size: 32rpx;
  line-height: 1;
}

.toolbar__icon--record {
  font-size: 28rpx;
}

.toolbar__label {
  font-size: 24rpx;
  color: #4A4A5A;
  line-height: 1;
}

.toolbar__divider {
  width: 1rpx;
  height: 40rpx;
  background: #E8E8F0;
  margin: 0 4rpx;
}

/* 录音脉冲动画 */
.toolbar__pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 80, 80, 0.15);
  animation: pulse 1.2s ease-in-out infinite;
  pointer-events: none;
}

@keyframes pulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
  50% { transform: translate(-50%, -50%) scale(1.15); opacity: 0.6; }
}
